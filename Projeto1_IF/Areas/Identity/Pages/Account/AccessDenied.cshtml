@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Acesso negado";
}

<header>
    <h1 class="text-danger">@ViewData["Title"]</h1>
    <p class="text-danger">Você não tem permissão para acessar esta página.</p>
    <p>Esta área é restrita ao perfil adequado. Se você acha que isso é um engano, entre em contato com o administrador.</p>
    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">Voltar ao início</a>
</header>
