@* Maurício Rimes Vieira *@
@model Projeto1_IF.Models.TbPaciente

@{
    ViewData["Title"] = "Editar Paciente";
}

<h1>Editar Paciente</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.IdPaciente">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdPaciente" />

            <div class="form-group mb-3">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Rg" class="control-label"></label>
                <input asp-for="Rg" class="form-control" />
                <span asp-validation-for="Rg" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Cpf" class="control-label"></label>
                <input asp-for="Cpf" class="form-control" />
                <span asp-validation-for="Cpf" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DataNascimento" class="control-label"></label>
                <input asp-for="DataNascimento" class="form-control" type="date" />
                <span asp-validation-for="DataNascimento" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NomeResponsavel" class="control-label"></label>
                <input asp-for="NomeResponsavel" class="form-control" />
                <span asp-validation-for="NomeResponsavel" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Sexo" class="control-label"></label>
                <select asp-for="Sexo" class="form-control">
                    <option value="">Selecione...</option>
                    <option value="M">Masculino</option>
                    <option value="F">Feminino</option>
                </select>
                <span asp-validation-for="Sexo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Etnia" class="control-label"></label>
                <select asp-for="Etnia" class="form-select">
                    <option value="">Selecione...</option>
                    <option value="1">Branca</option>
                    <option value="2">Preta</option>
                    <option value="3">Parda</option>
                    <option value="4">Amarela</option>
                    <option value="5">Indígena</option>
                </select>
                <span asp-validation-for="Etnia" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Endereco" class="control-label"></label>
                <input asp-for="Endereco" class="form-control" />
                <span asp-validation-for="Endereco" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Bairro" class="control-label"></label>
                <input asp-for="Bairro" class="form-control" />
                <span asp-validation-for="Bairro" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdCidade" class="control-label">Cidade</label>
                <select asp-for="IdCidade" class="form-select" asp-items="ViewBag.IdCidade">
                    <option value="">Selecione a cidade...</option>
                </select>
                <span asp-validation-for="IdCidade" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TelResidencial" class="control-label"></label>
                <input asp-for="TelResidencial" class="form-control" />
                <span asp-validation-for="TelResidencial" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TelComercial" class="control-label"></label>
                <input asp-for="TelComercial" class="form-control" />
                <span asp-validation-for="TelComercial" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TelCelular" class="control-label"></label>
                <input asp-for="TelCelular" class="form-control" />
                <span asp-validation-for="TelCelular" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Profissao" class="control-label"></label>
                <input asp-for="Profissao" class="form-control" />
                <span asp-validation-for="Profissao" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FlgAtleta" class="control-label"></label>
                <select asp-for="FlgAtleta" class="form-select">
                    <option value="">Não informado</option>
                    <option value="true">Sim</option>
                    <option value="false">Não</option>
                </select>
                <span asp-validation-for="FlgAtleta" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FlgGestante" class="control-label"></label>
                <select asp-for="FlgGestante" class="form-select">
                    <option value="">Não informado</option>
                    <option value="true">Sim</option>
                    <option value="false">Não</option>
                </select>
                <span asp-validation-for="FlgGestante" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Voltar à Lista</a>
</div>

@section Scripts {
    @* O partial carrega o jquery.validate; o pt-br deve vir DEPOIS para sobrescrever mensagens/métodos. *@
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/lib/jquery-validation/dist/jquery.validate.pt-br.js"></script>
}
