@* Maurício Rimes Vieira *@
@model Projeto1_IF.Models.TbProfissional

@{
    ViewData["Title"] = "Editar Profissional";
}

<h1>Editar Profissional</h1>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" asp-route-id="@Model.IdProfissional">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdProfissional" />

            <div class="mb-3">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Cpf" class="form-label"></label>
                    <input asp-for="Cpf" class="form-control" />
                    <span asp-validation-for="Cpf" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CrmCrn" class="form-label"></label>
                    <input asp-for="CrmCrn" class="form-control" />
                    <span asp-validation-for="CrmCrn" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Especialidade" class="form-label"></label>
                <input asp-for="Especialidade" class="form-control" />
                <span asp-validation-for="Especialidade" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Logradouro" class="form-label"></label>
                    <input asp-for="Logradouro" class="form-control" />
                    <span asp-validation-for="Logradouro" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Numero" class="form-label"></label>
                    <input asp-for="Numero" class="form-control" />
                    <span asp-validation-for="Numero" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Cep" class="form-label"></label>
                    <input asp-for="Cep" class="form-control" />
                    <span asp-validation-for="Cep" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="Bairro" class="form-label"></label>
                    <input asp-for="Bairro" class="form-control" />
                    <span asp-validation-for="Bairro" class="text-danger"></span>
                </div>
                <div class="col-md-5 mb-3">
                    <label asp-for="Cidade" class="form-label"></label>
                    <input asp-for="Cidade" class="form-control" />
                    <span asp-validation-for="Cidade" class="text-danger"></span>
                </div>
                <div class="col-md-2 mb-3">
                    <label asp-for="Estado" class="form-label"></label>
                    <input asp-for="Estado" class="form-control" />
                    <span asp-validation-for="Estado" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-2 mb-3">
                    <label asp-for="Ddd1" class="form-label"></label>
                    <input asp-for="Ddd1" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Telefone1" class="form-label"></label>
                    <input asp-for="Telefone1" class="form-control" />
                </div>
                <div class="col-md-2 mb-3">
                    <label asp-for="Ddd2" class="form-label"></label>
                    <input asp-for="Ddd2" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Telefone2" class="form-label"></label>
                    <input asp-for="Telefone2" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Salario" class="form-label"></label>
                <input asp-for="Salario" class="form-control" />
                <span asp-validation-for="Salario" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Salvar</button>
            <a asp-action="Index" class="btn btn-link">Voltar à Lista</a>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.pt-br.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
